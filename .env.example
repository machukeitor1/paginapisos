# JWT secret para autenticación de admin y vendedores
# Genera uno con: openssl rand -base64 32
JWT_SECRET=mi-secreto-super-seguro-2024

# Base de datos PostgreSQL (Render, Neon.tech o Supabase)
# Obtén esta URL desde tu proveedor PostgreSQL
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# Cloudinary (almacenamiento de imágenes gratuito)
# Crea una cuenta gratis en https://cloudinary.com
# Obtén estas credenciales desde Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
